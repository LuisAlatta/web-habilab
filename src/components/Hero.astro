---
---

<section
  id="inicio"
  class="relative min-h-screen flex items-center overflow-hidden"
  style="background: linear-gradient(135deg, #7B3FA0 0%, #5c2e7a 50%, #1A1A2E 100%);"
>
  <!-- Decorative dots -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-16 left-8 w-4 h-4 rounded-full bg-[#00C4DC] opacity-60"></div>
    <div class="absolute top-32 left-1/4 w-2 h-2 rounded-full bg-[#F4821F] opacity-80"></div>
    <div class="absolute top-24 right-1/3 w-3 h-3 rounded-full bg-[#00C4DC] opacity-50"></div>
    <div class="absolute bottom-32 left-1/3 w-2 h-2 rounded-full bg-[#F4821F] opacity-70"></div>
    <!-- Star SVG decoratives -->
    <svg class="absolute top-20 right-16 w-8 h-8 text-[#F4821F] opacity-70" viewBox="0 0 24 24" fill="currentColor">
      <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17 5.8 21.3l2.4-7.4L2 9.4h7.6z"/>
    </svg>
    <svg class="absolute bottom-40 right-20 w-6 h-6 text-[#00C4DC] opacity-60" viewBox="0 0 24 24" fill="currentColor">
      <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17 5.8 21.3l2.4-7.4L2 9.4h7.6z"/>
    </svg>
    <svg class="absolute top-1/2 left-6 w-5 h-5 text-[#7B3FA0] opacity-40" viewBox="0 0 24 24" fill="currentColor">
      <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17 5.8 21.3l2.4-7.4L2 9.4h7.6z"/>
    </svg>
  </div>

  <!-- Content -->
  <div class="max-w-6xl mx-auto px-4 py-28 grid md:grid-cols-2 gap-12 items-center w-full">
    <!-- Text column -->
    <div class="text-white">
      <span
        class="inline-block text-sm font-bold px-4 py-1.5 rounded-full mb-6"
        style="background-color: #F4821F;"
      >
        Laboratorio de habilidades para la vida
      </span>

      <h1 class="text-7xl md:text-8xl font-black text-white mb-4 leading-none">
        HabiLab
      </h1>

      <p class="text-2xl font-bold mb-4" style="color: #00C4DC;">
        Experimenta, aprende y crece
      </p>

      <p class="text-lg leading-relaxed mb-10 max-w-lg" style="color: rgba(255,255,255,0.80);">
        Un programa formativo y creativo que desarrolla habilidades socioemocionales
        en niños y adolescentes a través de talleres, mentorías y comunidad.
      </p>

      <div class="flex flex-wrap gap-4">
        <a href="#unete" class="btn-primary">
          Únete al proyecto →
        </a>
        <a href="#sobre" class="btn-ghost">
          Conoce más
        </a>
      </div>

      <!-- Stats row -->
      <div class="flex gap-8 mt-12">
        <div>
          <p class="text-3xl font-black text-white">6–17</p>
          <p class="text-sm font-semibold" style="color: rgba(255,255,255,0.65);">años de edad</p>
        </div>
        <div class="w-px" style="background: rgba(255,255,255,0.2);"></div>
        <div>
          <p class="text-3xl font-black text-white">5</p>
          <p class="text-sm font-semibold" style="color: rgba(255,255,255,0.65);">tipos de talleres</p>
        </div>
        <div class="w-px" style="background: rgba(255,255,255,0.2);"></div>
        <div>
          <p class="text-3xl font-black text-white">100%</p>
          <p class="text-sm font-semibold" style="color: rgba(255,255,255,0.65);">gratuito</p>
        </div>
      </div>
    </div>

    <!-- Image column -->
    <div class="relative hidden md:block">
      <div
        class="rounded-3xl overflow-hidden shadow-2xl border-4"
        style="border-color: #00C4DC;"
      >
        <img
          src="/images/foto-voluntarios-2.png"
          alt="Niños y adolescentes en HabiLab"
          class="w-full h-96 object-cover"
          width="600"
          height="400"
          loading="eager"
        />
      </div>

      <!-- Floating badge -->
      <div
        class="absolute -bottom-5 -left-5 text-white rounded-2xl p-4 shadow-2xl"
        style="background-color: #F4821F;"
      >
        <p class="font-black text-2xl leading-none">Club de</p>
        <p class="font-black text-2xl leading-none">Habilidades</p>
      </div>

      <!-- Second floating badge -->
      <div
        class="absolute -top-4 -right-4 text-white rounded-full p-3 shadow-xl"
        style="background-color: #00C4DC;"
      >
        <svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor">
          <path d="M9 11l3 3L22 4M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>
        </svg>
      </div>
    </div>
  </div>

  <!-- Bottom wave -->
  <div class="wave-bottom">
    <svg viewBox="0 0 1440 70" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="w-full h-16 md:h-20">
      <path d="M0,35 C240,70 480,0 720,35 C960,70 1200,0 1440,35 L1440,70 L0,70 Z" fill="#ffffff"/>
    </svg>
  </div>
</section>
