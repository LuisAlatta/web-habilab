---
const roles = [
  {
    color: '#00C4DC',
    title: 'Voluntario',
    description: 'Universitarios y profesionales que quieran hacer mentoría y generar impacto social.',
    href: '/voluntarios',
    cta: 'Postularme como voluntario',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>`,
  },
  {
    color: '#7B3FA0',
    title: 'Aliado',
    description: 'ONGs, escuelas y organizaciones que quieran apoyar o colaborar con el programa.',
    href: '/aliados',
    cta: 'Registrar alianza',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  },
];
---

<section
  id="unete"
  class="py-24 relative overflow-hidden"
  style="background-color: #1A1A2E;"
>
  <!-- Decorative elements -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-10 left-10 w-48 h-48 rounded-full opacity-10" style="background: #7B3FA0;"></div>
    <div class="absolute bottom-10 right-10 w-64 h-64 rounded-full opacity-10" style="background: #F4821F;"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 rounded-full opacity-5" style="background: #00C4DC;"></div>
  </div>

  <div class="max-w-6xl mx-auto px-4 relative">
    <!-- Header -->
    <div class="text-center mb-14">
      <span
        class="inline-block text-sm font-bold px-4 py-1.5 rounded-full mb-6"
        style="background-color: #F4821F; color: white;"
      >
        Sé parte de HabiLab
      </span>
      <h2 class="text-4xl md:text-5xl font-black text-white mb-6 leading-tight">
        Tu participación puede<br />
        <span style="color: #00C4DC;">marcar una diferencia</span>
      </h2>
      <p class="text-xl max-w-2xl mx-auto leading-relaxed" style="color: rgba(255,255,255,0.75);">
        Si deseas contribuir al desarrollo de niños y adolescentes y formar parte
        de un espacio educativo innovador y comunitario, puedes sumarte a HabiLab.
      </p>
    </div>

    <!-- Roles cards -->
    <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">
      {roles.map(role => (
        <div
          class="rounded-3xl p-8 text-white text-center flex flex-col"
          style={`background-color: ${role.color}20; border: 1px solid ${role.color}40;`}
        >
          <div
            class="w-14 h-14 rounded-2xl flex items-center justify-center mx-auto mb-4"
            style={`background-color: ${role.color}; color: white;`}
          >
            <Fragment set:html={role.icon} />
          </div>
          <h3 class="font-extrabold text-2xl mb-3 text-white">{role.title}</h3>
          <p class="text-base leading-relaxed mb-6 flex-grow" style="color: rgba(255,255,255,0.75);">{role.description}</p>
          <a
            href={role.href}
            class="inline-block px-8 py-3 font-bold rounded-full transition-all duration-200 hover:scale-105"
            style={`background-color: ${role.color}; color: white;`}
          >
            {role.cta} →
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
