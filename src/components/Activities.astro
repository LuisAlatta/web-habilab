---
const activities = [
  {
    color: '#F4821F',
    emoji: '🧠',
    title: 'Talleres socioemocionales',
    items: ['Autoestima y autoconocimiento', 'Manejo de emociones', 'Comunicación asertiva'],
    description: 'Desarrollamos inteligencia emocional y resiliencia a través de dinámicas grupales y reflexión guiada.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>`,
  },
  {
    color: '#7B3FA0',
    emoji: '🤝',
    title: 'Talleres sociales',
    items: ['Liderazgo positivo', 'Trabajo en equipo', 'Resolución pacífica de conflictos'],
    description: 'Fortalecemos la convivencia, la colaboración y las competencias de liderazgo comunitario.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>`,
  },
  {
    color: '#00C4DC',
    emoji: '🛡️',
    title: 'Talleres de prevención',
    items: ['Prevención de riesgos sociales', 'Uso responsable de la tecnología', 'Toma de decisiones saludables'],
    description: 'Equipamos a los participantes con herramientas para tomar decisiones informadas y responsables.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  },
  {
    color: '#F4821F',
    emoji: '🎨',
    title: 'Espacios creativos',
    items: ['Teatro pedagógico', 'Lectura creativa', 'Creación con materiales reciclados', 'Proyectos colectivos'],
    description: 'Arte, teatro y expresión creativa como canales para procesar emociones y construir identidad.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8"><circle cx="12" cy="12" r="10"/><path d="M8.56 2.75c4.37 6.03 6.02 9.42 8.03 17.72m2.54-15.38c-3.72 4.35-8.94 5.66-16.88 5.85m19.5 1.9c-3.5-3.92-8.72-7.57-15.5-7.9"/></svg>`,
  },
  {
    color: '#7B3FA0',
    emoji: '🏘️',
    title: 'Actividades comunitarias',
    items: ['Charlas para padres', 'Jornadas recreativas familiares', 'Ferias educativas comunitarias'],
    description: 'Involucramos a familias y comunidad para construir redes de apoyo duraderas.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  },
];
---

<section id="actividades" class="py-24 relative" style="background-color: #F8F6FF;">
  <!-- Top wave -->
  <div class="absolute top-0 left-0 right-0 overflow-hidden leading-none" style="transform: rotate(180deg);">
    <svg viewBox="0 0 1440 70" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="w-full h-16">
      <path d="M0,35 C240,0 480,70 720,35 C960,0 1200,70 1440,35 L1440,70 L0,70 Z" fill="#ffffff"/>
    </svg>
  </div>

  <div class="max-w-6xl mx-auto px-4 pt-6">
    <!-- Header -->
    <div class="text-center mb-14">
      <span
        class="inline-block text-sm font-bold px-4 py-1.5 rounded-full mb-4"
        style="background-color: #7B3FA0; color: white;"
      >
        Actividades del Proyecto
      </span>
      <h2 class="section-title mb-4">¿Qué hacemos en HabiLab?</h2>
      <p class="text-lg text-gray-600 max-w-xl mx-auto">
        Un programa integral con cinco líneas de acción que cubren el desarrollo
        completo de cada participante.
      </p>
    </div>

    <!-- Cards grid: 2-2-1 centered -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {activities.map((act, i) => (
        <div
          class={`bg-white rounded-3xl shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-200 overflow-hidden ${i === 4 ? 'sm:col-start-1 lg:col-start-2' : ''}`}
        >
          <!-- Color bar -->
          <div class="h-1.5" style={`background-color: ${act.color};`}></div>
          <div class="p-6">
            <!-- Icon -->
            <div
              class="w-14 h-14 rounded-2xl flex items-center justify-center mb-4"
              style={`background-color: ${act.color}18; color: ${act.color};`}
            >
              <Fragment set:html={act.icon} />
            </div>

            <h3 class="font-extrabold text-[#1A1A2E] text-xl mb-2">{act.title}</h3>
            <p class="text-sm text-gray-500 leading-relaxed mb-4">{act.description}</p>

            <!-- Items list -->
            <ul class="space-y-1">
              {act.items.map(item => (
                <li class="flex items-center gap-2 text-sm text-gray-600">
                  <span
                    class="w-1.5 h-1.5 rounded-full flex-shrink-0"
                    style={`background-color: ${act.color};`}
                  ></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom note -->
    <p class="text-center text-gray-500 mt-10 text-sm max-w-lg mx-auto">
      Estas actividades permiten que los niños y adolescentes
      <strong class="text-[#1A1A2E]">aprendan haciendo</strong>, experimentando
      y colaborando en un entorno seguro y estimulante.
    </p>
  </div>

  <!-- Bottom wave -->
  <div class="wave-bottom">
    <svg viewBox="0 0 1440 70" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="w-full h-16">
      <path d="M0,0 C360,70 1080,0 1440,35 L1440,70 L0,70 Z" fill="#1A1A2E"/>
    </svg>
  </div>
</section>
