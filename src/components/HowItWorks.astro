---
const steps = [
  {
    number: '01',
    color: '#F4821F',
    title: 'Inscripción',
    description: 'Niños, adolescentes y voluntarios se registran al programa de manera gratuita.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
  },
  {
    number: '02',
    color: '#7B3FA0',
    title: 'Formación de grupos',
    description: 'Se organizan grupos por edades e intereses para una participación activa y dinámica.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>`,
  },
  {
    number: '03',
    color: '#00C4DC',
    title: 'Talleres formativos',
    description: 'Sesiones prácticas de autoestima, emociones, comunicación, liderazgo y trabajo en equipo.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/></svg>`,
  },
  {
    number: '04',
    color: '#F4821F',
    title: 'Mentores',
    description: 'Voluntarios acompañan el proceso brindando orientación y apoyo emocional personalizado.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>`,
  },
  {
    number: '05',
    color: '#7B3FA0',
    title: 'Comunidad',
    description: 'Actividades comunitarias y familiares que fortalecen el vínculo entre participantes.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>`,
  },
  {
    number: '06',
    color: '#00C4DC',
    title: 'Proyectos creativos',
    description: 'Los participantes crean obras teatrales, historias y proyectos que reflejan lo aprendido.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
  },
];
---

<section id="como-funciona" class="py-24 relative" style="background-color: #F0E8F8;">
  <!-- Top wave -->
  <div class="absolute top-0 left-0 right-0 overflow-hidden leading-none" style="transform: rotate(180deg);">
    <svg viewBox="0 0 1440 70" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="w-full h-16">
      <path d="M0,35 C240,70 480,0 720,35 C960,70 1200,0 1440,35 L1440,70 L0,70 Z" fill="#ffffff"/>
    </svg>
  </div>

  <div class="max-w-6xl mx-auto px-4">
    <!-- Header -->
    <div class="text-center mb-14 pt-4">
      <span
        class="inline-block text-sm font-bold px-4 py-1.5 rounded-full mb-4"
        style="background-color: #7B3FA0; color: white;"
      >
        ¿Cómo Funciona?
      </span>
      <h2 class="section-title mb-4">Así funciona HabiLab</h2>
      <p class="text-lg text-gray-600 max-w-xl mx-auto">
        Un proceso pensado para que cada participante descubra, experimente y crezca
        junto a su comunidad.
      </p>
    </div>

    <!-- Steps grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-6">
      {steps.map(step => (
        <div class="bg-white rounded-3xl p-6 shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-200 relative overflow-hidden">
          <!-- Number badge -->
          <div
            class="w-10 h-10 rounded-full text-white font-black text-sm flex items-center justify-center mb-4"
            style={`background-color: ${step.color};`}
          >
            {step.number}
          </div>

          <!-- Icon -->
          <div
            class="w-12 h-12 rounded-2xl flex items-center justify-center mb-4"
            style={`background-color: ${step.color}20; color: ${step.color};`}
          >
            <Fragment set:html={step.icon} />
          </div>

          <h3 class="font-extrabold text-[#1A1A2E] text-lg mb-2">{step.title}</h3>
          <p class="text-sm text-gray-500 leading-relaxed">{step.description}</p>

          <!-- Decorative corner -->
          <div
            class="absolute top-0 right-0 w-16 h-16 rounded-bl-3xl opacity-10"
            style={`background-color: ${step.color};`}
          ></div>
        </div>
      ))}
    </div>
  </div>

  <!-- Bottom wave -->
  <div class="wave-bottom">
    <svg viewBox="0 0 1440 70" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="w-full h-16">
      <path d="M0,35 C240,0 480,70 720,35 C960,0 1200,70 1440,35 L1440,70 L0,70 Z" fill="#ffffff"/>
    </svg>
  </div>
</section>
