---
const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '';
const base = isHome ? '' : '/';
const navLinks = [
  { label: 'Sobre el Proyecto', href: `${base}#sobre` },
  { label: '¿Cómo Funciona?', href: `${base}#como-funciona` },
  { label: 'Actividades', href: `${base}#actividades` },
];
const homeHref = isHome ? '#inicio' : '/';
const uneteHref = `${base}#unete`;
---

<header class="sticky top-0 z-50 bg-white shadow-sm" id="site-header">
  <nav class="max-w-6xl mx-auto px-4 flex items-center justify-between h-16">
    <!-- Logo -->
    <a href={homeHref} aria-label="HabiLab inicio">
      <img
        src="/images/logo.png"
        alt="HabiLab"
        class="h-10 w-auto"
        width="160"
        height="40"
      />
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class="font-bold text-[#1A1A2E] hover:text-[#F4821F] transition-colors duration-200"
          >
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a href={uneteHref} class="btn-primary !py-2.5 !px-6 !text-base">
          Únete
        </a>
      </li>
    </ul>

    <!-- Mobile hamburger (CSS-only) -->
    <label for="mobile-menu-toggle" class="md:hidden cursor-pointer p-2" aria-label="Abrir menú">
      <svg class="w-6 h-6 text-[#1A1A2E]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
          d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </label>
  </nav>

  <!-- Mobile menu (CSS toggle) -->
  <input type="checkbox" id="mobile-menu-toggle" class="hidden peer" />
  <div class="hidden peer-checked:block md:hidden bg-white border-t border-gray-100 px-4 py-4">
    <ul class="flex flex-col gap-4">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class="block font-bold text-[#1A1A2E] hover:text-[#F4821F] transition-colors"
          >
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a href={uneteHref} class="btn-primary inline-block text-center !py-3 !text-base w-full">
          Únete al proyecto
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  // Add shadow on scroll
  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      header?.classList.add('shadow-md');
      header?.classList.remove('shadow-sm');
    } else {
      header?.classList.remove('shadow-md');
      header?.classList.add('shadow-sm');
    }
  });
</script>
