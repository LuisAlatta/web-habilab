---
const navLinks = [
  { label: 'Sobre el Proyecto', href: '#sobre' },
  { label: '¿Cómo Funciona?', href: '#como-funciona' },
  { label: 'Actividades', href: '#actividades' },
  { label: 'Únete', href: '#unete' },
];
---

<footer style="background-color: #1A1A2E;" class="border-t border-white/10">
  <div class="max-w-6xl mx-auto px-4 py-16">
    <div class="grid md:grid-cols-3 gap-12 mb-12">
      <!-- Column 1: Brand -->
      <div>
        <a href="#inicio">
          <img
            src="/images/logo-white.png"
            alt="HabiLab"
            class="h-12 w-auto mb-4"
            width="192"
            height="48"
          />
        </a>
        <p class="text-sm leading-relaxed mb-4" style="color: rgba(255,255,255,0.60);">
          Laboratorio de habilidades para la vida. Un espacio seguro donde
          niños y adolescentes descubren sus capacidades y crecen juntos.
        </p>
        <!-- Color dots brand identifier -->
        <div class="flex gap-2 mt-4">
          <span class="w-3 h-3 rounded-full" style="background-color: #F4821F;"></span>
          <span class="w-3 h-3 rounded-full" style="background-color: #7B3FA0;"></span>
          <span class="w-3 h-3 rounded-full" style="background-color: #00C4DC;"></span>
        </div>
      </div>

      <!-- Column 2: Quick links -->
      <div>
        <h4 class="font-extrabold text-white mb-4">Navegación</h4>
        <ul class="space-y-3">
          {navLinks.map(link => (
            <li>
              <a
                href={link.href}
                class="text-sm transition-colors duration-200 hover:text-white"
                style="color: rgba(255,255,255,0.60);"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Project info -->
      <div>
        <h4 class="font-extrabold text-white mb-4">El Proyecto</h4>
        <ul class="space-y-3">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0" style="color: #F4821F;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/>
            </svg>
            <span class="text-sm" style="color: rgba(255,255,255,0.60);">Público: Niños y adolescentes 6–17 años</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0" style="color: #7B3FA0;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
            </svg>
            <span class="text-sm" style="color: rgba(255,255,255,0.60);">Comunidades vulnerables del Perú</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0" style="color: #00C4DC;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            <span class="text-sm" style="color: rgba(255,255,255,0.60);">Parte de Munay Ruray</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="pt-8 flex flex-col md:flex-row items-center justify-between gap-4"
      style="border-top: 1px solid rgba(255,255,255,0.10);"
    >
      <p class="text-sm" style="color: rgba(255,255,255,0.40);">
        © 2025 HabiLab — Programa Social. Todos los derechos reservados.
      </p>
      <p class="text-xs" style="color: rgba(255,255,255,0.30);">
        "Experimenta, aprende y crece"
      </p>
    </div>
  </div>
</footer>
