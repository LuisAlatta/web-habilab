---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Registro de Aliados — HabiLab">
  <Header />
  <main>
    <section class="py-16 md:py-24" style="background-color: #1A1A2E;">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <span
          class="inline-block text-sm font-bold px-4 py-1.5 rounded-full mb-6"
          style="background-color: #7B3FA0; color: white;"
        >
          Alianzas HabiLab
        </span>
        <h1 class="text-4xl md:text-5xl font-black text-white mb-6 leading-tight">
          Registro de <span style="color: #F4821F;">Aliados</span>
        </h1>
        <p class="text-lg md:text-xl leading-relaxed" style="color: rgba(255,255,255,0.80);">
          Invitamos a ONGs, instituciones educativas y organizaciones a colaborar
          con HabiLab para generar impacto en la educación de niños y adolescentes.
        </p>
      </div>
    </section>

    <section class="py-16 bg-white">
      <div class="max-w-3xl mx-auto px-4">
        <form
          action="https://formsubmit.co/munayruray2025@gmail.com"
          method="POST"
          class="space-y-10"
        >
          <input type="hidden" name="_subject" value="Nuevo registro de Aliado — HabiLab" />
          <input type="hidden" name="_cc" value="newluisalatta@gmail.com" />
          <input type="hidden" name="_template" value="table" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_next" value="https://thehabilab.pe/gracias" />
          <input type="text" name="_honey" style="display:none" />

          <!-- Datos de la organización -->
          <fieldset class="space-y-5">
            <legend class="text-2xl font-black mb-4" style="color: #1A1A2E;">Datos de la organización</legend>
            <div>
              <label class="block font-bold mb-2 text-sm">Nombre de la organización *</label>
              <input type="text" name="Organización" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-[#7B3FA0] focus:outline-none" />
            </div>
            <div>
              <label class="block font-bold mb-2 text-sm">Tipo de organización *</label>
              <div class="grid grid-cols-2 gap-3">
                {['ONG','Institución educativa','Empresa','Otro'].map(t => (
                  <label class="flex items-center gap-2"><input type="radio" name="Tipo de organización" value={t} required /> {t}</label>
                ))}
              </div>
            </div>
            <div class="grid md:grid-cols-2 gap-5">
              <div>
                <label class="block font-bold mb-2 text-sm">RUC (opcional)</label>
                <input type="text" name="RUC" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-[#7B3FA0] focus:outline-none" />
              </div>
              <div>
                <label class="block font-bold mb-2 text-sm">Dirección *</label>
                <input type="text" name="Dirección" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-[#7B3FA0] focus:outline-none" />
              </div>
            </div>
          </fieldset>

          <!-- Representante -->
          <fieldset class="space-y-5">
            <legend class="text-2xl font-black mb-4" style="color: #1A1A2E;">Representante</legend>
            <div class="grid md:grid-cols-2 gap-5">
              <div>
                <label class="block font-bold mb-2 text-sm">Nombre completo *</label>
                <input type="text" name="Representante" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-[#7B3FA0] focus:outline-none" />
              </div>
              <div>
                <label class="block font-bold mb-2 text-sm">Cargo *</label>
                <input type="text" name="Cargo" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-[#7B3FA0] focus:outline-none" />
              </div>
              <div>
                <label class="block font-bold mb-2 text-sm">Teléfono *</label>
                <input type="tel" name="Teléfono" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-[#7B3FA0] focus:outline-none" />
              </div>
              <div>
                <label class="block font-bold mb-2 text-sm">Correo electrónico *</label>
                <input type="email" name="Correo" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-[#7B3FA0] focus:outline-none" />
              </div>
            </div>
          </fieldset>

          <!-- Tipo de colaboración -->
          <fieldset>
            <legend class="text-2xl font-black mb-4" style="color: #1A1A2E;">Tipo de colaboración</legend>
            <label class="block font-bold mb-2 text-sm">¿Cómo deseas apoyar? (puedes marcar varias)</label>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
              {['Financiamiento','Voluntariado corporativo','Espacios físicos','Capacitación','Difusión'].map(c => (
                <label class="flex items-center gap-2">
                  <input type="checkbox" name="Tipo de colaboración" value={c} /> {c}
                </label>
              ))}
            </div>
            <input type="text" name="Otra colaboración" placeholder="Otra forma de apoyo (opcional)" class="mt-3 w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-[#7B3FA0] focus:outline-none" />
          </fieldset>

          <!-- Experiencia -->
          <fieldset class="space-y-5">
            <legend class="text-2xl font-black mb-4" style="color: #1A1A2E;">Experiencia</legend>
            <div>
              <label class="block font-bold mb-2 text-sm">¿Has participado en proyectos sociales antes? *</label>
              <div class="flex gap-6">
                <label class="flex items-center gap-2"><input type="radio" name="Proyectos sociales previos" value="Sí" required /> Sí</label>
                <label class="flex items-center gap-2"><input type="radio" name="Proyectos sociales previos" value="No" /> No</label>
              </div>
            </div>
            <div>
              <label class="block font-bold mb-2 text-sm">Describe brevemente</label>
              <textarea name="Descripción de experiencia" rows="4" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-[#7B3FA0] focus:outline-none"></textarea>
            </div>
          </fieldset>

          <!-- Propuesta -->
          <fieldset>
            <legend class="text-2xl font-black mb-4" style="color: #1A1A2E;">Propuesta</legend>
            <label class="block font-bold mb-2 text-sm">¿Qué tipo de alianza propones? *</label>
            <textarea name="Propuesta de alianza" rows="4" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-[#7B3FA0] focus:outline-none"></textarea>
          </fieldset>

          <!-- Disponibilidad -->
          <fieldset>
            <legend class="text-2xl font-black mb-4" style="color: #1A1A2E;">Disponibilidad</legend>
            <label class="block font-bold mb-2 text-sm">¿Cuándo te gustaría iniciar la colaboración? *</label>
            <input type="text" name="Inicio de colaboración" placeholder="Ej: Mayo 2026" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-[#7B3FA0] focus:outline-none" />
          </fieldset>

          <div class="pt-4 text-center">
            <button type="submit" class="btn-primary !px-12 !py-4" style="background: linear-gradient(135deg, #7B3FA0, #F4821F);">
              Enviar registro →
            </button>
          </div>
        </form>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
