---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Postulación de Voluntarios — HabiLab">
  <Header />
  <main>
    <section class="py-16 md:py-24" style="background-color: #1A1A2E;">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <span
          class="inline-block text-sm font-bold px-4 py-1.5 rounded-full mb-6"
          style="background-color: #00C4DC; color: white;"
        >
          Voluntariado HabiLab
        </span>
        <h1 class="text-4xl md:text-5xl font-black text-white mb-6 leading-tight">
          Postulación de <span style="color: #00C4DC;">Voluntarios</span>
        </h1>
        <p class="text-lg md:text-xl leading-relaxed" style="color: rgba(255,255,255,0.80);">
          Buscamos universitarios y profesionales comprometidos con la educación y
          el impacto social que deseen brindar mentoría a niños y adolescentes.
        </p>
      </div>
    </section>

    <section class="py-16 bg-white">
      <div class="max-w-3xl mx-auto px-4">
        <form
          action="https://formsubmit.co/munayruray2025@gmail.com"
          method="POST"
          enctype="multipart/form-data"
          class="space-y-10"
        >
          <!-- FormSubmit config -->
          <input type="hidden" name="_subject" value="Nueva postulación de Voluntario — HabiLab" />
          <input type="hidden" name="_cc" value="newluisalatta@gmail.com" />
          <input type="hidden" name="_template" value="table" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_next" value="https://thehabilab.pe/gracias" />
          <input type="text" name="_honey" style="display:none" />

          <!-- Datos personales -->
          <fieldset class="space-y-5">
            <legend class="text-2xl font-black mb-4" style="color: #1A1A2E;">Datos personales</legend>
            <div class="grid md:grid-cols-2 gap-5">
              <div>
                <label class="block font-bold mb-2 text-sm">Nombres y apellidos *</label>
                <input type="text" name="Nombres y apellidos" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-[#00C4DC] focus:outline-none" />
              </div>
              <div>
                <label class="block font-bold mb-2 text-sm">Edad *</label>
                <input type="number" name="Edad" min="16" max="99" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-[#00C4DC] focus:outline-none" />
              </div>
              <div>
                <label class="block font-bold mb-2 text-sm">DNI *</label>
                <input type="text" name="DNI" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-[#00C4DC] focus:outline-none" />
              </div>
              <div>
                <label class="block font-bold mb-2 text-sm">Teléfono *</label>
                <input type="tel" name="Teléfono" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-[#00C4DC] focus:outline-none" />
              </div>
              <div>
                <label class="block font-bold mb-2 text-sm">Correo electrónico *</label>
                <input type="email" name="Correo" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-[#00C4DC] focus:outline-none" />
              </div>
              <div>
                <label class="block font-bold mb-2 text-sm">Ciudad *</label>
                <input type="text" name="Ciudad" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-[#00C4DC] focus:outline-none" />
              </div>
            </div>
          </fieldset>

          <!-- Formación académica -->
          <fieldset class="space-y-5">
            <legend class="text-2xl font-black mb-4" style="color: #1A1A2E;">Formación académica</legend>
            <div class="grid md:grid-cols-2 gap-5">
              <div>
                <label class="block font-bold mb-2 text-sm">Carrera / Profesión *</label>
                <input type="text" name="Carrera o profesión" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-[#00C4DC] focus:outline-none" />
              </div>
              <div>
                <label class="block font-bold mb-2 text-sm">Universidad o institución *</label>
                <input type="text" name="Universidad o institución" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-[#00C4DC] focus:outline-none" />
              </div>
              <div class="md:col-span-2">
                <label class="block font-bold mb-2 text-sm">Nivel *</label>
                <select name="Nivel" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-[#00C4DC] focus:outline-none bg-white">
                  <option value="">Selecciona una opción</option>
                  <option>Estudiante</option>
                  <option>Egresado</option>
                  <option>Titulado</option>
                </select>
              </div>
            </div>
          </fieldset>

          <!-- Experiencia -->
          <fieldset class="space-y-5">
            <legend class="text-2xl font-black mb-4" style="color: #1A1A2E;">Experiencia</legend>
            <div>
              <label class="block font-bold mb-2 text-sm">¿Tienes experiencia trabajando con niños o adolescentes? *</label>
              <div class="flex gap-6">
                <label class="flex items-center gap-2"><input type="radio" name="Experiencia con niños" value="Sí" required /> Sí</label>
                <label class="flex items-center gap-2"><input type="radio" name="Experiencia con niños" value="No" /> No</label>
              </div>
            </div>
            <div>
              <label class="block font-bold mb-2 text-sm">Describe tu experiencia</label>
              <textarea name="Descripción de experiencia" rows="4" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-[#00C4DC] focus:outline-none"></textarea>
            </div>
            <div>
              <label class="block font-bold mb-2 text-sm">Habilidades (puedes marcar varias)</label>
              <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
                {['Enseñanza','Liderazgo','Tecnología','Comunicación','Arte'].map(h => (
                  <label class="flex items-center gap-2">
                    <input type="checkbox" name="Habilidades" value={h} /> {h}
                  </label>
                ))}
              </div>
              <input type="text" name="Otra habilidad" placeholder="Otra habilidad (opcional)" class="mt-3 w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-[#00C4DC] focus:outline-none" />
            </div>
          </fieldset>

          <!-- Motivación -->
          <fieldset>
            <legend class="text-2xl font-black mb-4" style="color: #1A1A2E;">Motivación</legend>
            <label class="block font-bold mb-2 text-sm">¿Por qué deseas ser voluntario en HabiLab? *</label>
            <textarea name="Motivación" rows="4" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-[#00C4DC] focus:outline-none"></textarea>
          </fieldset>

          <!-- Disponibilidad -->
          <fieldset class="space-y-5">
            <legend class="text-2xl font-black mb-4" style="color: #1A1A2E;">Disponibilidad</legend>
            <div>
              <label class="block font-bold mb-2 text-sm">Días disponibles *</label>
              <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                {['Lunes','Martes','Miércoles','Jueves','Viernes','Sábado','Domingo'].map(d => (
                  <label class="flex items-center gap-2">
                    <input type="checkbox" name="Días disponibles" value={d} /> {d}
                  </label>
                ))}
              </div>
            </div>
            <div>
              <label class="block font-bold mb-2 text-sm">Horarios disponibles *</label>
              <input type="text" name="Horarios disponibles" placeholder="Ej: 4pm a 7pm" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-[#00C4DC] focus:outline-none" />
            </div>
            <div>
              <label class="block font-bold mb-2 text-sm">Modalidad preferida *</label>
              <select name="Modalidad" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:border-[#00C4DC] focus:outline-none bg-white">
                <option value="">Selecciona una opción</option>
                <option>Virtual</option>
                <option>Presencial</option>
                <option>Mixta</option>
              </select>
            </div>
          </fieldset>

          <!-- Compromiso -->
          <fieldset>
            <legend class="text-2xl font-black mb-4" style="color: #1A1A2E;">Compromiso</legend>
            <label class="block font-bold mb-2 text-sm">¿Cuánto tiempo puedes comprometerte? *</label>
            <div class="flex flex-wrap gap-6">
              <label class="flex items-center gap-2"><input type="radio" name="Compromiso" value="1 mes" required /> 1 mes</label>
              <label class="flex items-center gap-2"><input type="radio" name="Compromiso" value="3 meses" /> 3 meses</label>
              <label class="flex items-center gap-2"><input type="radio" name="Compromiso" value="6 meses" /> 6 meses</label>
            </div>
          </fieldset>

          <!-- CV -->
          <fieldset>
            <legend class="text-2xl font-black mb-4" style="color: #1A1A2E;">Adjuntar CV</legend>
            <label class="block font-bold mb-2 text-sm">Sube tu CV (PDF, DOC, DOCX) *</label>
            <input type="file" name="attachment" accept=".pdf,.doc,.docx" required class="w-full px-4 py-3 rounded-xl border border-gray-300 bg-white" />
          </fieldset>

          <div class="pt-4 text-center">
            <button type="submit" class="btn-primary !px-12 !py-4" style="background: linear-gradient(135deg, #00C4DC, #7B3FA0);">
              Enviar postulación →
            </button>
          </div>
        </form>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
